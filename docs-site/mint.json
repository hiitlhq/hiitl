        "getting-started/quickstart-python",
        "getting-started/quickstart-typescript",
        "getting-started/observe-first"
      ]
    },
    {
      "group": "Core Concepts",
      "pages": [
        "concepts/how-it-works",
        "concepts/envelope",
        "concepts/policies",
        "concepts/decisions",
        "concepts/audit-trail",
        "concepts/deployment-modes"
      ]
    },
    {
      "group": "SDK Reference",
      "pages": [
        {
          "group": "Python",
          "pages": [
            "sdk/python-installation",
            "sdk/python-evaluate",
            "sdk/python-configuration",
            "sdk/python-decision"
          ]
        },
        {
          "group": "TypeScript",
          "pages": [
            "sdk/typescript-installation",
            "sdk/typescript-evaluate",
            "sdk/typescript-configuration",
            "sdk/typescript-decision"
          ]
        }
      ]
