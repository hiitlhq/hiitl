      },
      {
        "name": "second_matching_rule",
        "priority": 90,
        "enabled": true,
        "conditions": {
          "field": "parameters.amount",
          "operator": "less_than",
          "value": 1000
        },
        "decision": "ALLOW",
        "reason_code": "SECOND_MATCH",
        "description": "Rule: second_matching_rule"
      }
    ]
  },
  "expected_decision": {
    "decision": "REQUIRE_APPROVAL",
    "allowed": false,
    "reason_codes": [
      "FIRST_MATCH"
    ]
  }
