{
  "test_id": "test_104_observe_always_allowed",
  "description": "OBSERVE_ALL mode: REQUIRE_APPROVAL decision becomes OBSERVE with allowed=true",
  "mode": "OBSERVE_ALL",
  "envelope": {
    "schema_version": "v1.0",
    "org_id": "org_1234567890abcdef",
    "environment": "prod",
