    ]
  },
  "expected_decision": {
    "decision": "OBSERVE",
    "allowed": true,
    "reason_codes": ["OBSERVED"],
    "would_be": "REQUIRE_APPROVAL",
    "would_be_reason_codes": ["PAYMENT_REQUIRES_APPROVAL"]
  }
