{
  "name": "check-test-policy",
  "version": "1.0",
  "rules": [
    {
      "name": "allow-small-amounts",
      "description": "Allow transactions under $1000",
      "priority": 100,
      "enabled": true,
      "decision": "ALLOW",
      "reason_code": "SMALL_AMOUNT",
      "conditions": {
        "field": "parameters.amount",
        "operator": "less_than",
        "value": 1000
      }
    },
    {
      "name": "block-large-amounts",
      "description": "Block transactions $1000 and above",
      "priority": 50,
      "enabled": true,
      "decision": "BLOCK",
      "reason_code": "LARGE_AMOUNT",
      "conditions": {
        "field": "parameters.amount",
        "operator": "greater_than_or_equal",
        "value": 1000
      }
    }
  ]
}
