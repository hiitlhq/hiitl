{
  "name": "test-policy",
  "version": "1.0",
  "rules": [
    {
      "name": "allow-small-amounts",
      "description": "Allow transactions under $1000",
      "priority": 100,
      "enabled": true,
      "decision": "ALLOW",
      "reason_code": "SMALL_AMOUNT",
      "conditions": {
        "field": "parameters.amount",
        "operator": "less_than",
        "value": 1000
      }
    }
  ]
}
